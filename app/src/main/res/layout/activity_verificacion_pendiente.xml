<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <!-- Título -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Registro Completo"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_gravity="center_horizontal"
        android:textColor="#000000"/>

    <!-- Mensaje de éxito -->
    <TextView
        android:id="@+id/tvSuccessMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Usuario registrado. Revisa tu correo para verificar la cuenta."
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        android:layout_gravity="center_horizontal"
        android:textColor="#000000"/>

    <!-- Sección de instrucciones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#F0F8FF"
        android:layout_marginTop="16dp">

        <!-- Icono de información -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_info"
            android:layout_gravity="start"
            android:layout_marginEnd="8dp"/>

        <!-- Título de la sección -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verificación de email requerida"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:textColor="#000000"/>

        <!-- Descripción -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hemos enviado un enlace de verificación a tu correo electrónico. Por favor:"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:textColor="#000000"/>

        <!-- Lista de sugerencias -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <!-- Sugerencia 1 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Revisa tu bandeja de entrada"
                android:textSize="14sp"
                android:textColor="#000000"/>

            <!-- Sugerencia 2 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Verifica también la carpeta de spam/correo no deseado"
                android:textSize="14sp"
                android:textColor="#000000"/>

            <!-- Sugerencia 3 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Haz clic en el enlace para activar tu cuenta"
                android:textSize="14sp"
                android:textColor="#000000"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Botón para reenviar correo -->
    <Button
        android:id="@+id/btnReenviarCorreo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reenviar correo de verificación"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:backgroundTint="#03683E"
        android:textColor="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>
</LinearLayout>